# Copy this file to `.env` to enable live integration tests against a real
# ComfyUI. `.env` is gitignored. Shell env vars override these values.

# Set to 1 to run the gated integration tests in `pnpm test`.
RELIT_LIVE=1

# Base URL of the ComfyUI instance to test against.
# Default port 8188 (OSS) or 8000 (desktop app).
RELIT_COMFY_URL=http://localhost:8000
